VITE_BACKEND_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=

# ------------------------------------------------------------------
#  WebRTC ICE / TURN (goi video/thoai)
# ------------------------------------------------------------------
# Mac dinh app dung STUN cua Google + TURN cong khai (OpenRelay) lam
# "best-effort". TURN cong khai mien phi KHONG on dinh -> cuoc goi khac
# mang (4G <-> Wi-Fi, sau NAT/tuong lua) co the bi den man hinh / khong
# co tieng. De goi on dinh, cau hinh TURN rieng qua cac bien duoi day.
#
# Cach 1 (don gian): cau hinh 1 TURN server.
#   VITE_TURN_URL co the la 1 hoac nhieu url ngan cach boi dau phay.
# VITE_TURN_URL=turn:your-turn-host:3478,turns:your-turn-host:443?transport=tcp
# VITE_TURN_USERNAME=your-username
# VITE_TURN_CREDENTIAL=your-credential
#
# Cach 2 (nang cao): ghi de HOAN TOAN danh sach iceServers bang JSON.
#   Neu dat, se bo qua toan bo cau hinh mac dinh + VITE_TURN_*.
# VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:your-host:3478","username":"u","credential":"p"}]
#
# Goi y dich vu TURN: Metered.ca (mien phi 50GB/thang), Twilio NTS,
# hoac tu host coturn (https://github.com/coturn/coturn).