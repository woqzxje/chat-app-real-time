# MongoDB connection (local dev or Atlas)
MONGODB_URL=mongodb://localhost:27017

# BAT BUOC: khoa bi mat JWT (server se khong khoi chay neu thieu bien nay).
# Tao chuoi ngau nhien dai, vi du: python -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_long_random_secret

# So ngay het han cua token (mac dinh 7)
JWT_EXPIRES_DAYS=7

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS: danh sach origin duoc phep (ngan cach bang dau phay), khong dung "*"
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Cac host duoc phep tai file (chong SSRF). Mac dinh: res.cloudinary.com
ALLOWED_DOWNLOAD_HOSTS=res.cloudinary.com

# Google OAuth client id (de trong neu khong dung Google login)
GOOGLE_CLIENT_ID=

# Rate limiting cho endpoint auth (tuy chon)
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=60

PORT=5000
